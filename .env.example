# Quiz World local development example.
# Do not paste production secrets here.

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase local. Run `npx supabase status` after `npx supabase start`
# and copy the local anon/service keys here.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Phase 1 signup/auth settings.
ADMIN_EMAILS=admin@example.com
QUIZ_WORLD_ID=00000000-0000-4000-8000-000000000001
MAX_INITIAL_MEMBERS=10

# NOTIFICATION_PHASE is intentionally not used in Phase 0-1.
# Phase 1 notification behavior stays as a code constant: "polling".
